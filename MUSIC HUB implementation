CSS:

body {
    font-family: Arial, sans-serif;
    text-align: center;
    background-color: #f4f4f4;
}

header {
    padding: 15px;
    background-color: #333;
    color: white;
    font-size: 18px;
}

/* Updated Gallery Styling for Compact Layout */
.gallery {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 15px; /* Reduced spacing */
}

/* Updated Album Box Styling */
.album {
    width: 200px; /* Shrunk width */
    padding: 10px; /* Reduced padding */
    background-color: white;
    box-shadow: 0px 0px 5px rgba(0,0,0,0.1);
    text-align: center;
    font-size: 12px; /* Smaller font */
}

/* Smaller Images */
img {
    width: 80%; /* Shrunk image size */
    height: auto;
}

/* Compact Button */
.lyrics-btn {
    display: inline-block;
    margin-top: 8px;
    padding: 8px;
    background-color: #333;
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-size: 12px;
}

/* Modal Styling */
.modal {
    display: none;
    position: fixed;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.5);
}

/* Show modal when targeted */
.modal:target {
    display: flex;
    justify-content: center;
    align-items: center;
}

/* Shrunk Modal Content */
.modal-content {
    background-color: white;
    width: 40%; /* Reduced width */
    padding: 15px; /* Less padding */
    box-shadow: 0px 0px 5px rgba(0,0,0,0.1);
    text-align: center;
    font-size: 12px; /* Smaller font */
}

/* Close Button */
.close {
    display: block;
    margin-top: 15px;
    font-size: 20px; /* Shrunk font */
    color: black;
    text-decoration: none;
}

